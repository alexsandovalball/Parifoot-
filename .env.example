# ─────────────────────────────────────────────────────────────────────────────
# Parifoot – environment variable template
# Copy this file to .env and fill in your values.
# ─────────────────────────────────────────────────────────────────────────────

# Telegram bot token from @BotFather
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# Your personal Telegram chat ID (integer).
# Send /start to @userinfobot to find yours.
TELEGRAM_CHAT_ID=123456789

# The Odds API key – https://the-odds-api.com/
ODDS_API_KEY=your_odds_api_key_here

# API-Football key – https://www.api-football.com/
API_FOOTBALL_KEY=your_api_football_key_here

# ── Algorithm parameters (optional – defaults shown) ────────────────────────

# Target combined odds window
TARGET_ODDS_MIN=10.0
TARGET_ODDS_MAX=12.0

# Foundation legs odds range
FOUNDATION_ODDS_MIN=1.15
FOUNDATION_ODDS_MAX=1.50

# Booster legs odds range
BOOSTER_ODDS_MIN=2.00
BOOSTER_ODDS_MAX=3.00

# Number of foundation / booster legs
FOUNDATION_LEGS_MIN=4
FOUNDATION_LEGS_MAX=6
BOOSTER_LEGS_COUNT=1

# Minimum historical scoring/BTTS rate to qualify a stat-backed leg (0–1)
MIN_SCORING_RATE=0.70

# Flat daily stake in USD used for P&L / ROI calculation
DAILY_STAKE_USD=10.0

# Daily ticket send time (UTC, 24-h)
DAILY_SEND_HOUR=9
DAILY_SEND_MINUTE=0

# SQLite database file path
DATABASE_PATH=parifoot.db
